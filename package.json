{
  "name": "ao3-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm run dev:server\" \"npm run dev --workspace @ao3hub/web\"",
    "dev:server": "go run ./cmd/ao3hub",
    "dev:web": "npm run dev --workspace @ao3hub/web",
    "typecheck": "go test ./... && npm run typecheck --workspace @ao3hub/web",
    "build:web": "npm run build --workspace @ao3hub/web",
    "build": "node scripts/build-go.mjs",
    "ci": "npm run typecheck && npm run build",
    "ota:manifest": "go run ./cmd/ao3hub-manifest",
    "start": "go run ./cmd/ao3hub"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
