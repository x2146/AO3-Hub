{
  "name": "ao3-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"bun run dev:server\" \"bun run --cwd web dev\"",
    "dev:server": "go run ./cmd/ao3hub",
    "dev:web": "bun run --cwd web dev",
    "typecheck": "go test ./... && bun run --cwd web typecheck",
    "build:web": "bun run --cwd web build",
    "build": "bun run scripts/build-go.mjs",
    "ci": "bun run typecheck && bun run build",
    "ota:manifest": "go run ./cmd/ao3hub-manifest",
    "start": "go run ./cmd/ao3hub"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
